# 이 파일을 복사해서 .env 로 만든 뒤 값을 채우세요.  (cp .env.example .env)
# .env 에는 실제 비밀키가 들어가며 git 에 올라가지 않습니다.

# ===== 데이터베이스 (Supabase / PostgreSQL) =====
# Supabase 대시보드 > 프로젝트 > Connect 버튼 > "ORMs" 탭(또는 Connection string)에서 복사하세요.
# [YOUR-PASSWORD] 자리에는 프로젝트 만들 때 정한 DB 비밀번호를 넣습니다.
#
# DATABASE_URL : 앱이 평소에 쓰는 주소 = "Transaction pooler" (포트 6543, 끝에 ?pgbouncer=true)
# DIRECT_URL   : 표 만들기(마이그레이션)용 주소 = "Session pooler" 또는 "Direct" (포트 5432)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ===== 인증 (NextAuth) =====
# 임의의 비밀키 생성: npx auth secret
AUTH_SECRET="여기에-임의의-비밀키를-넣으세요"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ===== 카카오 로그인 (선택) =====
# https://developers.kakao.com 에서 발급
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ===== 네이버 로그인 (선택) =====
# https://developers.naver.com 에서 발급
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

