# 이 파일을 복사해서 .env 로 만든 뒤 값을 채우세요.  (cp .env.example .env)
# .env 에는 실제 비밀키가 들어가며 git 에 올라가지 않습니다.

# ===== 데이터베이스 =====
DATABASE_URL="file:./dev.db"

# ===== 인증 (NextAuth) =====
# 임의의 비밀키 생성: npx auth secret
AUTH_SECRET="여기에-임의의-비밀키를-넣으세요"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ===== 카카오 로그인 (선택) =====
# https://developers.kakao.com 에서 발급
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ===== 네이버 로그인 (선택) =====
# https://developers.naver.com 에서 발급
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ===== 토스페이먼츠 결제 =====
# 아래는 토스페이먼츠 공개 테스트 키입니다. 실제 결제를 받으려면 실키로 교체하세요.
NEXT_PUBLIC_TOSS_CLIENT_KEY="test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq"
TOSS_SECRET_KEY="test_sk_zXLkKEypNArWmo50nX3lmeaxYG5R"
